# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=naneka
DB_USER=naneka_user
DB_PASSWORD=changeme

# ─── Flutterwave ─────────────────────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_WEBHOOK_HASH=your_webhook_verification_hash
# tx_ref prefix — do not change after going live
FLUTTERWAVE_TX_REF_PREFIX=NANEKA

# ─── WAHA (WhatsApp) ─────────────────────────────────────────────────────────
WAHA_BASE_URL=http://localhost:3001
WAHA_API_KEY=your_waha_api_key
WAHA_SESSION=default

# ─── Textbee (SMS) ───────────────────────────────────────────────────────────
TEXTBEE_BASE_URL=http://your-textbee-host
TEXTBEE_API_KEY=your_textbee_api_key
TEXTBEE_DEVICE_ID=your_device_id

# ─── Traccar (GPS) ───────────────────────────────────────────────────────────
TRACCAR_BASE_URL=http://your-traccar-host:8082
TRACCAR_EMAIL=admin@example.com
TRACCAR_PASSWORD=changeme
# The Traccar device ID for the Phase 1 delivery vehicle
TRACCAR_VEHICLE_DEVICE_ID=1

# ─── Media Processing ────────────────────────────────────────────────────────
# remove.bg API key — required for background removal feature.
# Free tier: 50 preview images/month. Get a key at https://www.remove.bg/api
# Leave blank to disable background removal (resize + watermark still work).
REMOVE_BG_API_KEY=

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Personal Access Token — used to call the GitHub API (e.g. trigger workflows,
# read repo contents). Scopes needed depend on use-case; minimum: repo or workflow.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO_OWNER=lianasekro-ship-it
GITHUB_REPO_NAME=naneka

# ─── Currency ────────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=TZS
