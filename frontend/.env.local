# Local / Codespace dev override.
# Blanking VITE_API_URL forces axios baseURL to '' so the Vite dev-server proxy
# (vite.config.js → proxy['/api'] → http://localhost:3000) is used instead of
# hitting the Vercel-deployed backend directly.
# Production: Vercel dashboard env vars override this at build time.
VITE_API_URL=
